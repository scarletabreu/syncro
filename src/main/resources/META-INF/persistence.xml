<persistence xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="MiUnidadPersistencia" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.codewithmosh.model.Usuario</class>
        <class>com.codewithmosh.model.Evento</class>
        <class>com.codewithmosh.model.Inscripcion</class>
        <properties>
            <property name="hibernate.connection.provider_class"
                      value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>

            <property name="hibernate.hikari.jdbcUrl" value="jdbc:h2:tcp://localhost:9092/~/parcial2"/>
            <property name="hibernate.hikari.driverClassName" value="org.h2.Driver"/>
            <property name="hibernate.hikari.username" value="sa"/>
            <property name="hibernate.hikari.password" value="sa"/>
            <property name="hibernate.hikari.maximumPoolSize" value="10"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>

        </properties>
    </persistence-unit>
</persistence>